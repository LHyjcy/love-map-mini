<view class="container">
  <view wx:if="{{!ready}}" class="muted">加载中…</view>

  <block wx:elif="{{!loggedIn}}">
    <view class="card">
      <view class="title">回忆</view>
      <view class="muted">登录后可记录你们的回忆。</view>
      <button class="btn" bindtap="goMe">去登录</button>
    </view>
  </block>

  <block wx:elif="{{!bound}}">
    <view class="card">
      <view class="title">回忆</view>
      <view class="muted">绑定情侣关系后才能记录回忆。</view>
      <button class="btn" bindtap="goMe">去绑定</button>
    </view>
  </block>

  <block wx:else>
    <view class="card">
      <view class="title">记录回忆</view>

      <block wx:if="{{places.length > 0}}">
        <picker mode="selector" range="{{placeLabels}}" value="{{placeIndex}}" bindchange="onPlace">
          <view class="row mem-picker">
            <text class="label">关联地点</text>
            <text class="value">{{placeLabels[placeIndex]}}</text>
          </view>
        </picker>
        <input class="input" placeholder="标题" value="{{form.title}}" bindinput="onTitle" />
        <input class="input" placeholder="内容（可选）" value="{{form.content}}" bindinput="onContent" />
        <input class="input" placeholder="心情（可选）" value="{{form.mood}}" bindinput="onMood" />
        <button class="btn" bindtap="addMemory">记录</button>
      </block>

      <view wx:else class="muted">还没有地点，请先到地图添加地点。</view>
    </view>

    <view class="card">
      <view class="title">回忆列表</view>
      <view wx:if="{{memories.length === 0}}" class="muted">还没有回忆，去记录第一条吧。</view>
      <view wx:for="{{memories}}" wx:key="id" class="list-item">
        <view class="value">{{item.title}}</view>
        <view class="muted">{{item.mood}} · {{item.mediaCount}} 张照片</view>
        <view wx:if="{{item.content}}" class="mem-content">{{item.content}}</view>
      </view>
    </view>
  </block>
</view>
