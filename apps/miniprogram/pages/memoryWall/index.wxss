/* 回忆墙：立体回忆相册。复用全局 app.wxss，下为本页特有样式。 */

/* ---- 头部概览卡片 ---- */
.hero {
  background: linear-gradient(135deg, #6a58b8 0%, #8a6fd6 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(84, 68, 135, 0.22);
}
.hero-title {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
}
.hero-sub {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 26rpx;
}

/* ---- 相册容器：开启透视，让缩放产生纵深感 ---- */
.album {
  /* perspective 让两侧卡片的缩放/位移获得景深 */
  perspective: 1200rpx;
  margin-bottom: 28rpx;
}
.album-swiper {
  height: 760rpx;
  /* 给缩放卡片留出阴影与位移空间，避免被裁切 */
  overflow: visible;
}

/* ---- 单张回忆卡片 ---- */
.mcard {
  box-sizing: border-box;
  height: 720rpx;
  margin: 12rpx 14rpx;
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 44rpx rgba(84, 68, 135, 0.22);
  /* 深度核心：所有卡片共用过渡，居中/两侧切换时平滑缩放 */
  transition: transform 0.3s ease, opacity 0.3s ease;
  transform-origin: center center;
}
/* 居中（当前）卡片：原始大小，处于最前 */
.mcard--active {
  transform: scale(1);
  opacity: 1;
}
/* 两侧卡片：缩小 + 下沉 + 半透明，营造"后退一层"的立体层级 */
.mcard--side {
  transform: scale(0.9) translateY(14rpx);
  opacity: 0.85;
}

/* ---- 封面 ---- */
.cover {
  position: relative;
  width: 100%;
  height: 420rpx;
  background: #efecfa;
}
.cover-img {
  width: 100%;
  height: 100%;
  display: block;
}
.cover-ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 暖色渐变占位 */
  background: linear-gradient(135deg, #ffd3b6 0%, #ffaaa5 55%, #d6a4ff 100%);
}
.cover-ph-emoji {
  font-size: 110rpx;
}

/* 多图角标 */
.photo-count {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.45);
  color: #ffffff;
  font-size: 22rpx;
}

/* 标题渐变带 */
.cover-grad {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 48rpx 28rpx 22rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
}
.cover-title {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.35);
}

/* ---- 卡片正文 ---- */
.mbody {
  padding: 24rpx 28rpx 28rpx;
}
.mcontent {
  color: #4a4360;
  font-size: 27rpx;
  line-height: 1.5;
  /* 两行截断 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.tags {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
}
.tag {
  margin: 0 12rpx 12rpx 0;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #544487;
  background: #efecfa;
}
.mmeta {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.mmeta-date {
  color: #9a93b0;
  font-size: 24rpx;
}
.mmeta-mood {
  color: #6a58b8;
  font-size: 24rpx;
}

/* ---- 分页圆点 ---- */
.dots {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}
.dot {
  width: 12rpx;
  height: 12rpx;
  margin: 0 8rpx;
  border-radius: 999rpx;
  background: #d9d3f0;
  transition: width 0.3s ease, background 0.3s ease;
}
.dot--on {
  width: 30rpx;
  background: #6a58b8;
}

/* ---- 空 / 门控状态 ---- */
.empty {
  margin: 80rpx 0 28rpx;
  text-align: center;
}
.empty-emoji {
  font-size: 90rpx;
}
.empty-title {
  margin-top: 18rpx;
  color: #6b6580;
  font-size: 30rpx;
  font-weight: 600;
}
.empty-hint {
  margin-top: 12rpx;
  color: #999999;
  font-size: 26rpx;
}
.gate-btn {
  margin: 36rpx auto 0;
  width: 320rpx;
}
