/* pages/qa/index.wxss */
.center {
  text-align: center;
}

.question {
  font-size: 32rpx;
  line-height: 1.6;
  color: #2a2540;
  font-weight: 500;
}

.textarea {
  width: 100%;
  box-sizing: border-box;
  min-height: 200rpx;
  margin-top: 16rpx;
  padding: 20rpx 24rpx;
  background: #f5f4fb;
  border-radius: 14rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.answer-label {
  margin-top: 20rpx;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  color: #6b6580;
}

.answer-block {
  padding: 20rpx 24rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}

.answer-block.mine {
  background: #efecfa;
  color: #2a2540;
}

.answer-block.partner {
  background: #fdeef2;
  color: #2a2540;
}

.hint {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999999;
  text-align: center;
}
