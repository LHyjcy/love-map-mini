<view class="container">
  <view wx:if="{{!ready}}" class="muted">加载中…</view>

  <block wx:elif="{{!loggedIn}}">
    <view class="card">
      <view class="title">计划安排</view>
      <view class="muted">登录后可把想去的地方安排成计划。</view>
      <button class="btn" bindtap="goMe">去登录</button>
    </view>
  </block>

  <block wx:elif="{{!bound}}">
    <view class="card">
      <view class="title">计划安排</view>
      <view class="muted">绑定情侣关系后才能安排计划。</view>
      <button class="btn" bindtap="goMe">去绑定</button>
    </view>
  </block>

  <block wx:else>
    <view class="card">
      <view class="title">从想去清单选择</view>
      <view wx:if="{{wishlist.length === 0}}" class="muted">想去清单还是空的，先去地图添加一个想去的地方吧。</view>
      <view wx:for="{{wishlist}}" wx:key="id" class="row">
        <view class="value">
          {{item.title}}
          <view wx:if="{{item.address}}" class="muted">{{item.address}}</view>
        </view>
        <button class="btn ghost mini" bindtap="promote" data-id="{{item.id}}" disabled="{{promoting}}">设为计划</button>
      </view>
      <button class="btn ghost" bindtap="goAddPlace">＋ 添加想去地点</button>
    </view>

    <view class="card">
      <view class="title">当前计划</view>
      <view wx:if="{{plans.length === 0}}" class="muted">还没有计划，从上面的想去清单里挑一个安排吧。</view>
      <view wx:for="{{plans}}" wx:key="id" class="list-item" bindtap="goPlan" data-id="{{item.id}}">
        <view class="value">{{item.title}}</view>
        <view wx:if="{{item.address}}" class="muted">{{item.address}}</view>
      </view>
    </view>
  </block>
</view>
