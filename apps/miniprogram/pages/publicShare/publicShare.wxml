<view class="container">
  <view wx:if="{{!ready}}" class="muted">加载中…</view>

  <block wx:elif="{{!loggedIn}}">
    <view class="card">
      <view class="title">公开分享</view>
      <view class="muted">登录后可生成只读公开地图分享。</view>
      <button class="btn" bindtap="goMe">去登录</button>
    </view>
  </block>

  <block wx:elif="{{!bound}}">
    <view class="card">
      <view class="title">公开分享</view>
      <view class="muted">绑定情侣关系后才能创建公开分享。</view>
      <button class="btn" bindtap="goMe">去绑定</button>
    </view>
  </block>

  <block wx:else>
    <view class="card">
      <view class="title">公开地图分享</view>
      <view class="muted">公开分享默认关闭，仅展示标记为「公开」的内容，坐标会做模糊处理（完整地图渲染为后续版本）。</view>
      <input class="input" placeholder="分享标题" value="{{title}}" bindinput="onTitle" />
      <button class="btn" bindtap="createShare" disabled="{{creating}}">{{creating ? '创建中…' : '创建分享'}}</button>
    </view>

    <view class="card">
      <view class="title">我的分享</view>
      <view wx:if="{{shares.length === 0}}" class="muted">还没有分享记录。</view>
      <view wx:for="{{shares}}" wx:key="id" class="list-item">
        <view class="row">
          <view class="value">{{item.title}}</view>
          <text class="badge {{item.enabled ? 'green' : 'gray'}}">{{item.enabled ? '已开启' : '已关闭'}}</text>
        </view>
        <view class="muted">分享码：{{item.shareCode}} · {{item.createdText}}</view>
        <block wx:if="{{item.enabled}}">
          <view class="muted">公开链接：</view>
          <text class="share-url" selectable="{{true}}" user-select="{{true}}">{{item.shareUrl}}</text>
          <button
            class="btn ghost mini"
            bindtap="copyUrl"
            data-url="{{item.shareUrl}}"
          >复制链接</button>
        </block>
        <button
          class="btn ghost mini"
          bindtap="toggleShare"
          data-id="{{item.id}}"
          data-enabled="{{item.enabled}}"
          disabled="{{togglingId === item.id}}"
        >{{togglingId === item.id ? '处理中…' : (item.enabled ? '关闭分享' : '开启分享')}}</button>
      </view>
    </view>
  </block>
</view>
