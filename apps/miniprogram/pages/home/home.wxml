<view class="container">
  <!-- 未登录 -->
  <view wx:if="{{!loading && !loggedIn}}" class="card center">
    <view class="title">欢迎来到 love-map-mini</view>
    <view class="muted">记录你们一起去过的地方与点滴</view>
    <button class="btn" bindtap="goMe">去登录</button>
  </view>

  <!-- 已登录未绑定 -->
  <view wx:if="{{!loading && loggedIn && !bound}}" class="card center">
    <view class="title">还没有绑定另一半</view>
    <view class="muted">生成或输入邀请码完成绑定后即可使用</view>
    <button class="btn" bindtap="goMe">去绑定</button>
  </view>

  <!-- 已绑定：dashboard -->
  <block wx:if="{{!loading && bound && dash}}">
    <view class="hero">
      <view class="hero-num">{{dash.daysTogether === null ? '—' : dash.daysTogether}}</view>
      <view class="hero-label">在一起的日子</view>
    </view>

    <view class="row">
      <view class="stat card">
        <view class="stat-num">{{dash.pointsBalance}}</view>
        <view class="muted">我的积分</view>
      </view>
      <view class="stat card">
        <view class="stat-num">{{dash.pendingTasks}}</view>
        <view class="muted">待办任务</view>
      </view>
    </view>

    <button class="btn block" bindtap="signin">每日签到 +5</button>

    <!-- 今日心情（接口异常时自动隐藏） -->
    <view wx:if="{{moodReady}}" class="card mood-card" bindtap="goMood">
      <view class="mood-head">
        <text class="title">今日心情</text>
        <text class="badge">去记录 ›</text>
      </view>
      <view class="mood-row">
        <view class="mood-cell">
          <view class="mood-emoji">{{myMood}}</view>
          <view class="muted">我的</view>
        </view>
        <view class="mood-cell">
          <view class="mood-emoji">{{partnerMood}}</view>
          <view class="muted">TA 的</view>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="title">即将到来</view>
      <view wx:if="{{dash.upcomingEvents.length === 0}}" class="muted">暂无日程</view>
      <view wx:for="{{dash.upcomingEvents}}" wx:key="id" class="line" bindtap="goEvents">
        <text>{{item.title}}</text>
        <text class="badge">{{item.daysUntil === 0 ? '今天' : item.daysUntil + ' 天后'}}</text>
      </view>
    </view>

    <view class="card">
      <view class="title">最近回忆</view>
      <view wx:if="{{dash.recentMemories.length === 0}}" class="muted">还没有回忆，去地图添加吧</view>
      <view wx:for="{{dash.recentMemories}}" wx:key="id" class="line" bindtap="goMap">
        <text>{{item.title}}</text>
      </view>
    </view>

    <view class="card">
      <view class="title">快捷入口</view>
      <view class="qe-grid">
        <view class="qe" bindtap="goCheckin"><view class="qe-ic">📍</view><text>打卡</text></view>
        <view class="qe" bindtap="goMemories"><view class="qe-ic">📝</view><text>写回忆</text></view>
        <view class="qe" bindtap="goTasks"><view class="qe-ic">🎯</view><text>发任务</text></view>
        <view class="qe" bindtap="goPlan"><view class="qe-ic">📅</view><text>加计划</text></view>
        <view class="qe" bindtap="goAddPlace"><view class="qe-ic">➕</view><text>加地点</text></view>
        <view class="qe" bindtap="goTimeline"><view class="qe-ic">🕒</view><text>时间轴</text></view>
        <view class="qe" bindtap="goWishlist"><view class="qe-ic">💜</view><text>想去</text></view>
        <view class="qe" bindtap="goMap"><view class="qe-ic">🗺️</view><text>地图</text></view>
      </view>
    </view>

    <!-- 情侣问答快捷入口 -->
    <view class="card cell" bindtap="goQa">
      <view class="cell-main">
        <text class="cell-ic">💬</text>
        <text>情侣问答</text>
      </view>
      <text class="badge">去回答 ›</text>
    </view>
  </block>

  <view wx:if="{{loading}}" class="card center muted">加载中…</view>
</view>
