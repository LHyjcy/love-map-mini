/* pages/home/home.wxss */
.center {
  text-align: center;
}

.hero {
  background: linear-gradient(135deg, #6a5acd, #544487);
  border-radius: 24rpx;
  padding: 56rpx 32rpx;
  color: #ffffff;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(84, 68, 135, 0.25);
}

.hero-num {
  font-size: 88rpx;
  font-weight: 700;
  line-height: 1.1;
}

.hero-label {
  margin-top: 8rpx;
  font-size: 26rpx;
  opacity: 0.85;
}

.row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.stat {
  flex: 1;
  text-align: center;
  margin-bottom: 0;
}

.stat-num {
  font-size: 52rpx;
  font-weight: 700;
  color: #544487;
}

.line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-top: 1rpx solid #f0eef8;
}

.line:first-of-type {
  border-top: none;
}

.badge {
  font-size: 24rpx;
  color: #544487;
  background: #efecfa;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.btn {
  margin-top: 24rpx;
  background: #544487;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.btn.block {
  width: 100%;
}

.btn.ghost {
  flex: 1;
  margin-top: 0;
  background: #ffffff;
  color: #544487;
  border: 1rpx solid #d9d3f0;
}

/* 今日心情卡 */
.mood-card {
  margin-bottom: 24rpx;
}
.mood-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.mood-row {
  display: flex;
  margin-top: 16rpx;
}
.mood-cell {
  flex: 1;
  text-align: center;
}
.mood-emoji {
  font-size: 56rpx;
  line-height: 1.2;
}

/* 通用入口行（情侣问答等） */
.cell {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.cell-main {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #333333;
}
.cell-ic {
  font-size: 40rpx;
  margin-right: 16rpx;
}

/* 快捷入口宫格 */
.qe-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 8rpx;
}
.qe {
  width: 25%;
  box-sizing: border-box;
  padding: 18rpx 0;
  text-align: center;
  color: #544487;
  font-size: 24rpx;
}
.qe-ic {
  font-size: 44rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}
