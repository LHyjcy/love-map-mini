/* pages/home/home.wxss */
.center {
  text-align: center;
}

.hero {
  background: linear-gradient(135deg, #6a5acd, #544487);
  border-radius: 24rpx;
  padding: 56rpx 32rpx;
  color: #ffffff;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(84, 68, 135, 0.25);
}

.hero-num {
  font-size: 88rpx;
  font-weight: 700;
  line-height: 1.1;
}

.hero-label {
  margin-top: 8rpx;
  font-size: 26rpx;
  opacity: 0.85;
}

.row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.stat {
  flex: 1;
  text-align: center;
  margin-bottom: 0;
}

.stat-num {
  font-size: 52rpx;
  font-weight: 700;
  color: #544487;
}

.line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-top: 1rpx solid #f0eef8;
}

.line:first-of-type {
  border-top: none;
}

.badge {
  font-size: 24rpx;
  color: #544487;
  background: #efecfa;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.btn {
  margin-top: 24rpx;
  background: #544487;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.btn.block {
  width: 100%;
}

.btn.ghost {
  flex: 1;
  margin-top: 0;
  background: #ffffff;
  color: #544487;
  border: 1rpx solid #d9d3f0;
}
