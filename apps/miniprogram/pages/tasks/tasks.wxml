<view class="container">
  <!-- 未登录 / 未绑定 -->
  <view wx:if="{{ready && !loggedIn}}" class="card center">
    <view class="title">任务</view>
    <view class="muted">登录后可以给对方发布任务、赚取积分。</view>
    <button class="btn" bindtap="goMe">去『我的』登录</button>
  </view>
  <view wx:elif="{{ready && !bound}}" class="card center">
    <view class="title">任务</view>
    <view class="muted">先绑定情侣，才能互相发布任务。</view>
    <button class="btn" bindtap="goMe">去绑定</button>
  </view>

  <!-- 已绑定 -->
  <block wx:if="{{ready && bound}}">
    <view class="card">
      <view class="title">发布任务给 {{partner.nickname || '对方'}}</view>
      <view class="tpl-row">
        <text
          wx:for="{{templates}}"
          wx:key="title"
          class="badge tpl-chip"
          data-index="{{index}}"
          bindtap="useTemplate"
        >{{item.title}} +{{item.points}}</text>
      </view>
      <input class="input" placeholder="任务标题，如：买杯奶茶" value="{{form.title}}" bindinput="onTitle" />
      <input class="input" type="number" placeholder="完成可得积分（可空）" value="{{form.points}}" bindinput="onPoints" />
      <button class="btn" bindtap="createTask">发布</button>
    </view>

    <view class="card">
      <view class="title">任务列表</view>
      <view wx:if="{{tasks.length === 0}}" class="muted">还没有任务</view>
      <view wx:for="{{tasks}}" wx:key="id" class="list-item">
        <view class="row">
          <text class="value">{{item.title}}</text>
          <text class="badge {{item.badgeClass}}">{{item.statusText}}</text>
        </view>
        <view class="row">
          <text class="muted">{{item.points}} 分 · {{item.mine ? '我发布' : '指派给我'}}</text>
          <view>
            <button wx:if="{{item.canAccept}}" class="btn mini" data-id="{{item.id}}" data-action="accept" bindtap="act">接受</button>
            <button wx:if="{{item.canReject}}" class="btn mini ghost" data-id="{{item.id}}" data-action="reject" bindtap="act">拒绝</button>
            <button wx:if="{{item.canComplete}}" class="btn mini" data-id="{{item.id}}" data-action="complete" bindtap="act">完成</button>
            <button wx:if="{{item.canConfirm}}" class="btn mini" data-id="{{item.id}}" data-action="confirm" bindtap="act">确认发分</button>
            <button wx:if="{{item.canCancel}}" class="btn mini ghost" data-id="{{item.id}}" data-action="cancel" bindtap="act">取消</button>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
