<view class="container" wx:if="{{ready}}">

  <block wx:if="{{!loggedIn}}">
    <view class="card">
      <view class="title">未登录</view>
      <view class="muted">请先登录后再使用位置打卡功能。</view>
      <button class="btn" bindtap="goBind">去登录</button>
    </view>
  </block>

  <block wx:elif="{{!bound}}">
    <view class="card">
      <view class="title">未绑定情侣</view>
      <view class="muted">绑定对方后才能打卡并共享位置。</view>
      <button class="btn" bindtap="goBind">去绑定</button>
    </view>
  </block>

  <block wx:else>
    <view class="card">
      <view class="title">位置打卡</view>
      <view class="row">
        <text class="label">共享范围</text>
        <picker mode="selector" range="{{shareLabels}}" value="{{shareIndex}}" bindchange="onShareChange">
          <view class="value">{{shareLabels[shareIndex]}}</view>
        </picker>
      </view>
      <button class="btn" bindtap="doCheckin">打卡</button>
      <view class="muted">打卡由你主动发起。共享范围默认为「仅自己」。只有当你选择「共享给对方」且未过期时，对方才能看到你的位置。</view>
    </view>

    <view class="card">
      <view class="row">
        <view class="title">对方最近位置</view>
        <button class="btn mini ghost" bindtap="refreshPartner">刷新对方位置</button>
      </view>
      <block wx:if="{{partner}}">
        <view class="row">
          <text class="label">坐标</text>
          <text class="value">{{partner.latitude}}, {{partner.longitude}}</text>
        </view>
        <view class="row">
          <text class="label">距离</text>
          <text class="value">距离 {{distanceText}}</text>
        </view>
      </block>
      <view wx:else class="muted">对方暂未共享位置</view>
    </view>

    <view class="card">
      <view class="title">我的打卡记录</view>
      <view wx:if="{{checkins.length === 0}}" class="muted">暂无打卡记录</view>
      <view class="list-item" wx:for="{{checkins}}" wx:key="id">
        <text class="badge {{item.shareScope === 'self' ? 'gray' : 'green'}}">{{item.shareLabel}}</text>
        <text class="muted">{{item.createdAt}}</text>
      </view>
    </view>
  </block>

</view>
