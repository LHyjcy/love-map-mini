/* pages/review/index.wxss */

.center {
  text-align: center;
}

/* 周期切换 chips */
.rv-toggle {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.rv-chip {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: #544487;
  background: #ffffff;
  border: 1rpx solid #d9d3f0;
  transition: background 0.15s ease, color 0.15s ease;
}

.rv-chip.active {
  background: #544487;
  color: #ffffff;
  border-color: #544487;
}

/* 大数字统计卡 */
.rv-stats {
  background: linear-gradient(135deg, #ffffff 0%, #f4f1fc 100%);
}

.rv-sub {
  margin-bottom: 12rpx;
}

.rv-line {
  font-size: 34rpx;
  color: #2a2540;
  line-height: 1.8;
}

.rv-num {
  font-size: 52rpx;
  font-weight: 700;
  color: #544487;
  padding: 0 6rpx;
}

.rv-warm {
  margin-top: 20rpx;
}

/* AI 回顾文案卡 */
.rv-summary-card {
  background: linear-gradient(135deg, #fff7f0 0%, #fdeef3 100%);
  border: 1rpx solid #f3dcd0;
  position: relative;
}

.rv-summary-quote {
  font-size: 64rpx;
  line-height: 1;
  color: #e2a98f;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.rv-summary-text {
  font-size: 30rpx;
  line-height: 1.9;
  color: #4a3f3a;
  white-space: pre-wrap;
}

.rv-ai-btn {
  margin-bottom: 24rpx;
}

/* 标签徽章 */
.rv-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.rv-tag {
  font-size: 26rpx;
}

/* 近期回忆条目 */
.rv-mem {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 离屏海报画布：移出可视区域，仅用于绘制导出 */
.rv-poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: 0;
}
