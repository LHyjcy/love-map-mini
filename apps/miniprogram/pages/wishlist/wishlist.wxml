<view class="container">
  <view wx:if="{{!ready}}" class="muted">加载中…</view>

  <block wx:elif="{{!loggedIn}}">
    <view class="card">
      <view class="title">想去清单</view>
      <view class="muted">登录后可收藏想和 TA 一起去的地方。</view>
      <button class="btn" bindtap="goMe">去登录</button>
    </view>
  </block>

  <block wx:elif="{{!bound}}">
    <view class="card">
      <view class="title">想去清单</view>
      <view class="muted">绑定情侣关系后才能使用想去清单。</view>
      <button class="btn" bindtap="goMe">去绑定</button>
    </view>
  </block>

  <block wx:else>
    <view class="card">
      <view class="title">想去清单</view>
      <view wx:if="{{places.length === 0}}" class="muted">还没有想去的地方，去地图添加一个吧。</view>
      <view wx:for="{{places}}" wx:key="id" class="list-item" bindtap="goPlace" data-id="{{item.id}}">
        <view class="value">{{item.title}}</view>
        <view wx:if="{{item.address}}" class="muted">{{item.address}}</view>
        <view class="muted">点进可投票 · 一起决定要不要去</view>
      </view>
      <button class="btn ghost" bindtap="goAddPlace">＋ 添加想去地点</button>
    </view>
  </block>
</view>
