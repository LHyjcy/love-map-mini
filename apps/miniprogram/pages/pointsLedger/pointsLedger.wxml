<view class="container">
  <view wx:if="{{!ready}}" class="muted">加载中…</view>

  <block wx:elif="{{!loggedIn}}">
    <view class="card">
      <view class="title">积分流水</view>
      <view class="muted">登录后可查看积分明细。</view>
      <button class="btn" bindtap="goMe">去登录</button>
    </view>
  </block>

  <block wx:elif="{{!bound}}">
    <view class="card">
      <view class="title">积分流水</view>
      <view class="muted">绑定情侣关系后才能查看积分。</view>
      <button class="btn" bindtap="goMe">去绑定</button>
    </view>
  </block>

  <block wx:else>
    <view class="card">
      <view class="row">
        <text class="label">当前积分</text>
        <text class="badge green">{{balance}}</text>
      </view>
    </view>

    <view class="card">
      <view class="title">明细</view>
      <view wx:if="{{ledger.length === 0}}" class="muted">还没有积分记录。</view>
      <view wx:for="{{ledger}}" wx:key="id" class="row pl-item">
        <view class="pl-left">
          <view class="value">{{item.sourceLabel}}</view>
          <view class="muted">{{item.metaText}}</view>
        </view>
        <text class="pl-pts {{item.positive ? 'pos' : 'neg'}}">{{item.pointsText}}</text>
      </view>
    </view>
  </block>
</view>
