<view class="container">
  <view wx:if="{{!ready}}" class="muted">加载中…</view>

  <block wx:elif="{{!loggedIn}}">
    <view class="card">
      <view class="title">时间轴</view>
      <view class="muted">登录后可按时间回看回忆。</view>
      <button class="btn" bindtap="goMe">去登录</button>
    </view>
  </block>

  <block wx:elif="{{!bound}}">
    <view class="card">
      <view class="title">时间轴</view>
      <view class="muted">绑定情侣关系后才能查看回忆时间轴。</view>
      <button class="btn" bindtap="goMe">去绑定</button>
    </view>
  </block>

  <block wx:else>
    <view class="card">
      <view class="title">回忆时间轴</view>
      <view wx:if="{{items.length === 0}}" class="muted">还没有回忆，去地图记录第一条吧。</view>
      <view wx:for="{{items}}" wx:key="id" class="tl-item" bindtap="goMemory" data-id="{{item.id}}">
        <view class="tl-date">{{item.dateText}}</view>
        <view class="tl-body">
          <view class="value">{{item.title}}</view>
          <view class="muted">{{item.mood}} · {{item.mediaCount}} 张照片</view>
        </view>
      </view>
    </view>
  </block>
</view>
