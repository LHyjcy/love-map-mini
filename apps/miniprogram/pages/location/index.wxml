<view class="loc-page">
  <view wx:if="{{!ready}}" class="container muted">加载中…</view>

  <block wx:elif="{{!loggedIn}}">
    <view class="container"><view class="card"><view class="title">位置共享</view><view class="muted">登录后可使用临时位置共享。</view><button class="btn" bindtap="goMe">去登录</button></view></view>
  </block>

  <block wx:elif="{{!bound}}">
    <view class="container"><view class="card"><view class="title">位置共享</view><view class="muted">绑定情侣关系后可临时共享位置。</view><button class="btn" bindtap="goMe">去绑定</button></view></view>
  </block>

  <block wx:else>
    <map
      class="loc-map"
      latitude="{{latitude}}"
      longitude="{{longitude}}"
      markers="{{markers}}"
      scale="14"
      show-location
    ></map>

    <view class="panel">
      <view class="card">
        <view class="row">
          <text class="label">我的共享</text>
          <text class="badge {{sharing ? 'green' : 'gray'}}">{{sharing ? '共享中' : '未共享'}}</text>
        </view>
        <view wx:if="{{sharing}}" class="muted">到期：{{expiresText}}</view>
        <view wx:if="{{accuracyHint}}" class="muted">{{accuracyHint}}</view>

        <view wx:if="{{!sharing}}" class="row">
          <button class="btn mini" bindtap="startShare" data-minutes="30">共享 30 分钟</button>
          <button class="btn mini" bindtap="startShare" data-minutes="120">共享 2 小时</button>
        </view>
        <button wx:else class="btn ghost" bindtap="stopShare">停止共享</button>
      </view>

      <view class="card">
        <view class="row">
          <text class="label">TA 的位置</text>
          <text class="badge {{partnerSharing ? 'green' : 'gray'}}">{{partnerSharing ? '共享中' : '未共享'}}</text>
        </view>
        <view wx:if="{{partnerSharing}}" class="muted">{{partnerUpdatedText}}</view>
        <view wx:if="{{distanceText}}" class="row"><text class="label">直线距离</text><text class="value">{{distanceText}}</text></view>
        <view wx:if="{{!partnerSharing}}" class="muted">TA 还没有开启共享。</view>
      </view>

      <view class="card privacy">
        <view class="muted">{{privacyText}}</view>
      </view>
    </view>
  </block>
</view>
