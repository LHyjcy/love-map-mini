/* 立体封面头图：圆角 + 阴影营造“卡片浮起”，溢出裁剪让放大动画与渐变带不越界。 */
.cover {
  position: relative;
  width: 100%;
  height: 480rpx;
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 48rpx rgba(42, 37, 64, 0.28);
  background: #f0eef8;
}

.cover-img {
  width: 100%;
  height: 100%;
  display: block;
  /* 起始放大 1.06，配合 cover-in 缓动回到 1，形成轻微视差/放大入场。 */
  transform: scale(1.06);
  transition: transform 900ms ease-out;
}
.cover.cover-in .cover-img {
  transform: scale(1);
}

/* 底部渐变带：透明 -> 半透明黑，承托白色标题/日期，保证可读性。 */
.cover-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 60%;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.55));
  pointer-events: none;
}

.cover-meta {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 28rpx;
  pointer-events: none;
}
.cover-title {
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.45);
}
.cover-date {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 26rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.45);
}

.cover-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
}

.mem-content {
  margin-top: 16rpx;
  color: #2a2540;
  line-height: 1.6;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}
.tag-badge {
  margin: 0 12rpx 12rpx 0;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.btn-sm {
  width: auto;
  margin: 0;
  padding: 8rpx 24rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

/* 深度缩略图：圆角 + 阴影让每张照片像浮起的小卡片。 */
.photo {
  width: 200rpx;
  height: 200rpx;
  border-radius: 18rpx;
  margin: 8rpx 16rpx 16rpx 0;
  background: #f0eef8;
  box-shadow: 0 10rpx 22rpx rgba(42, 37, 64, 0.18);
}

/* 首张（封面同源）略微放大并加重阴影，强化层次。 */
.photo-lead {
  transform: scale(1.04);
  box-shadow: 0 14rpx 30rpx rgba(42, 37, 64, 0.26);
}
