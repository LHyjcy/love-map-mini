<view class="container">
  <view wx:if="{{!ready}}" class="muted">加载中…</view>

  <block wx:elif="{{!memory}}">
    <view class="card">
      <view class="title">回忆详情</view>
      <view class="muted">回忆不存在或无权访问。</view>
    </view>
  </block>

  <block wx:else>
    <!-- 立体封面头图：有照片时取首图，aspectFill 大图 + 底部渐变带承载标题/日期，入场轻微放大。 -->
    <view wx:if="{{coverUrl}}" class="cover {{coverLoaded ? 'cover-in' : ''}}">
      <image class="cover-img" src="{{coverUrl}}" mode="aspectFill" bindtap="previewImage" data-url="{{coverUrl}}" />
      <view class="cover-mask"></view>
      <view class="cover-meta">
        <view class="cover-title">{{memory.title}}</view>
        <text wx:if="{{dateText}}" class="cover-date">{{dateText}}</text>
      </view>
      <text class="cover-badge badge">{{visLabel}}</text>
    </view>

    <view class="card">
      <view wx:if="{{!coverUrl}}" class="row">
        <view class="title">{{memory.title}}</view>
        <text class="badge">{{visLabel}}</text>
      </view>
      <view wx:if="{{dateText}}" class="row">
        <text class="label">日期</text>
        <text class="value">{{dateText}}</text>
      </view>
      <view wx:if="{{memory.mood}}" class="row">
        <text class="label">心情</text>
        <text class="value">{{memory.mood}}</text>
      </view>
      <view wx:if="{{memory.content}}" class="mem-content">{{memory.content}}</view>
      <view wx:if="{{tagList.length > 0}}" class="tag-list">
        <text wx:for="{{tagList}}" wx:key="*this" class="badge tag-badge">{{item}}</text>
      </view>
      <button class="btn ghost" bindtap="removeMemory" disabled="{{deleting}}">{{deleting ? '删除中…' : '删除回忆'}}</button>
    </view>

    <view class="card">
      <view class="row">
        <view class="title">照片（{{media.length}}）</view>
        <button class="btn ghost btn-sm" bindtap="addPhoto" disabled="{{uploading}}">
          {{uploading ? '上传中…' : '添加照片'}}
        </button>
      </view>
      <view wx:if="{{media.length === 0}}" class="muted">还没有照片。</view>
      <view class="photo-grid">
        <image
          wx:for="{{media}}"
          wx:key="id"
          class="photo {{index === 0 ? 'photo-lead' : ''}}"
          src="{{item.thumb}}"
          mode="aspectFill"
          bindtap="previewImage"
          data-url="{{item.fileUrl}}"
        />
      </view>
    </view>
  </block>
</view>
