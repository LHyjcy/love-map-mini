# love-map-mini API — environment example
# 复制为 .env 后填写本地值。切勿提交真实密钥到仓库。

# 服务端口与环境
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# 数据库（Phase 3 起启用）。Prisma 需要此变量。
# 格式：mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL="mysql://user:password@localhost:3306/love_map_mini"

# 鉴权（Phase 4 起启用）。生产必须设置 ≥16 位随机字符串；占位/过短密钥会拒绝启动（fail-closed）。
# 开发未设置时使用占位密钥并告警。
JWT_SECRET="change-me-do-not-commit"
# 登录态有效期（@fastify/jwt 格式，如 7d / 12h）
JWT_EXPIRES_IN="7d"

# mock 登录（体验登录）。开发环境默认开启；生产默认关闭，
# 私用自托管需要「体验登录+邀请码绑定」时显式设置 MOCK_LOGIN_ENABLED=true。
MOCK_LOGIN_ENABLED=""

# 微信登录（Phase 11 起启用）。AppSecret 切勿提交真实值；未配置时 /api/auth/wechat-login 返回 501。
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""

# 对象存储（Phase 12 起启用）。provider 可选 local | cos | oss | disk：
# - local：仅开发用，不真正持久化（uploadUrl 为 null）。
# - cos/oss：纯 node:crypto 预签名直传，无需厂商 SDK；需 REGION/BUCKET/KEY 四项齐全。
# - disk：照片落本服务器磁盘（私用自托管，免 COS）；需 STORAGE_PUBLIC_BASE_URL 指向本服务地址。
# 访问密钥仅服务端读取，绝不返回前端、绝不提交真实值。
STORAGE_PROVIDER="local"
STORAGE_REGION=""
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_ACCESS_KEY_SECRET=""
STORAGE_PUBLIC_BASE_URL=""
# disk provider 的照片落盘目录（相对或绝对路径，默认 uploads）
STORAGE_DISK_DIR="uploads"

# 公开 web-share 页面的允许来源（CORS）。
# 默认 * ；生产应填 web-share 部署域名，如 https://share.example.com
PUBLIC_WEB_ORIGIN=""

# ── 地图模块（地图改造）──────────────────────────────────────────────
# 位置共享最新位置缓存 + WebSocket。未设置 REDIS_URL 时退化为进程内内存存储（仅单实例可用）。
REDIS_URL=""

# 地图服务商（MapProvider 适配层）。key 仅后端读取，绝不写入小程序前端。
# 未配置 key 时：逆地址/搜索返回「未配置」，distance 用 Haversine 前端/后端兜底。
MAP_PROVIDER="tencent"
MAP_FALLBACK_PROVIDER="amap"
TENCENT_MAP_KEY=""
AMAP_KEY=""
BAIDU_MAP_AK=""

# AI 文案（可选）。未配置 AI_API_KEY 时使用本地模板兜底，不产生任何外部调用。
# 兼容 OpenAI 风格 /chat/completions 接口；key 仅后端读取，绝不进入小程序端。
AI_API_KEY=""
AI_API_BASE="https://api.openai.com/v1"
AI_MODEL="gpt-4o-mini"
