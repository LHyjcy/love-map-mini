# love-map-mini API — environment example
# 复制为 .env 后填写本地值。切勿提交真实密钥到仓库。

# 服务端口与环境
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# 数据库（Phase 3 起启用）。Prisma 需要此变量。
# 格式：mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL="mysql://user:password@localhost:3306/love_map_mini"

# 鉴权（Phase 4 起启用）。生产必须设置；开发未设置时使用占位密钥并告警。
JWT_SECRET="change-me-do-not-commit"
# 登录态有效期（@fastify/jwt 格式，如 7d / 12h）
JWT_EXPIRES_IN="7d"

# 微信登录（Phase 11 起启用）。AppSecret 切勿提交真实值；未配置时 /api/auth/wechat-login 返回 501。
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""

# 对象存储（Phase 12 起启用）。provider=local 仅开发用；cos/oss 需引入厂商 SDK 后接线。
# 访问密钥仅服务端读取，绝不返回前端、绝不提交真实值。
STORAGE_PROVIDER="local"
STORAGE_REGION=""
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_ACCESS_KEY_SECRET=""
STORAGE_PUBLIC_BASE_URL=""
