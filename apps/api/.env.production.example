# love-map-mini API — 生产环境变量示例（production）
# 复制为 .env 并填真实值；切勿提交真实密钥。
# 生产真实密钥应通过容器 env / 密钥管理服务 / 进程管理器 env 注入，本文件仅作占位模板。

# 服务端口与环境
NODE_ENV=production                                  # 生产环境：禁用 mock 登录
PORT=3000                                            # 监听端口；反向代理（Nginx/Caddy）转发到此端口
HOST=0.0.0.0                                         # 容器/服务器内监听全部网卡

# 数据库（Prisma 需要）。格式：mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL="mysql://love_map:<db-password>@127.0.0.1:3306/love_map_mini"  # 生产 MySQL 连接串

# 鉴权。JWT_SECRET 生产必填且必须为强随机值；缺失会直接启动失败（绝不回退占位）。
JWT_SECRET="<生产强随机密钥-请用 openssl rand -hex 32 生成>"  # 登录令牌签名密钥，切勿提交
JWT_EXPIRES_IN="7d"                                  # 登录态有效期（@fastify/jwt 格式，如 7d / 12h）

# 微信登录（来自微信公众平台 → 开发管理 → 开发设置）。
WECHAT_APP_ID="<wx-app-id>"                          # 小程序 AppID
WECHAT_APP_SECRET="<wx-app-secret>"                  # 小程序 AppSecret，仅服务端读取，切勿提交

# 对象存储（腾讯云 COS 签名直传）。访问密钥仅服务端读取，绝不返回前端、绝不提交真实值。
STORAGE_PROVIDER="cos"                               # 生产用 cos（local 仅开发）
STORAGE_REGION="ap-guangzhou"                        # 存储地域，如 ap-guangzhou
STORAGE_BUCKET="myapp-1250000000"                    # bucket 名，COS 含 APPID（如 myapp-1250000000）
STORAGE_ACCESS_KEY_ID="<cos-secret-id>"              # 子账号 SecretId，仅服务端读取，切勿提交
STORAGE_ACCESS_KEY_SECRET="<cos-secret-key>"         # 子账号 SecretKey，仅服务端读取，切勿提交
STORAGE_PUBLIC_BASE_URL="https://cdn.example.com"    # 可选：CDN/自定义域名；不设则用默认 COS 域名拼 fileUrl

# 公开 web-share 页面的允许来源（CORS）。生产收紧为该静态站点确切域名。
PUBLIC_WEB_ORIGIN="https://share.example.com"        # web-share 部署域名；默认 * 仅供开发

# ── 地图模块 ─────────────────────────────────────────────────────────
# 位置共享最新位置缓存 + WebSocket。生产建议配置 Redis；未设置时退化为进程内内存（仅单实例可用）。
REDIS_URL="redis://127.0.0.1:6379"                   # Redis 连接串；多实例/PM2 cluster 必填

# 地图服务商（MapProvider 适配层）。key 仅后端读取，绝不写入小程序前端。
MAP_PROVIDER="tencent"                               # 主用地图服务商：tencent / amap / baidu
MAP_FALLBACK_PROVIDER="amap"                         # 兜底地图服务商
TENCENT_MAP_KEY="<tencent-map-key>"                  # 腾讯位置服务 key，仅服务端读取，切勿提交
AMAP_KEY="<amap-key>"                                # 高德地图 key，仅服务端读取，切勿提交
BAIDU_MAP_AK="<baidu-map-ak>"                        # 百度地图 AK，仅服务端读取，切勿提交

# AI 文案（可选）。未配置 AI_API_KEY 时使用本地模板兜底，不产生任何外部调用。
# 兼容 OpenAI 风格 /chat/completions 接口；key 仅后端读取，绝不进入小程序端。
AI_API_KEY="<ai-api-key>"                            # AI 服务密钥，仅服务端读取，切勿提交
AI_API_BASE="https://api.openai.com/v1"              # AI 接口基础地址
AI_MODEL="gpt-4o-mini"                               # 模型名称
